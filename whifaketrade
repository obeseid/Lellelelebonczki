-- ─── HELPERS ─────────────────────────────────────────────────────────────────

local function showAlert(msg, color, duration)
    alertLabel.Text       = "⚠  " .. msg
    alertLabel.TextColor3 = color or Color3.fromRGB(255,120,120)
    alertBanner.BackgroundColor3 = (color == SUCCESS)
        and Color3.fromRGB(10,40,20) or Color3.fromRGB(40,10,10)
    alertBanner.Visible = true
    task.delay(duration or 2.5, function()
        alertBanner.Visible = false
    end)
end

local function formatValue(n)
    if n >= 1000000 then return ("%.1fm"):format(n/1000000)
    elseif n >= 1000 then return ("%.1fk"):format(n/1000)
    else return tostring(n) end
end

local function totalValue(items)
    local t = 0
    for _, it in pairs(items) do t += (it.value or 0) * (it.amt or 1) end
    return t
end

local function updateLabels()
    local lc = 0 for _ in pairs(State.localItems) do lc+=1 end
    local oc = 0 for _ in pairs(State.otherItems) do oc+=1 end
    localUI.countLbl.Text = ("Offer (%d/%d)"):format(lc, MAX_ITEMS)
    otherUI.countLbl.Text = ("Offer (%d/%d)"):format(oc, MAX_ITEMS)
    localUI.valueLbl.Text = ("Value: %s tokens"):format(formatValue(totalValue(State.localItems)))
    otherUI.valueLbl.Text = ("Value: %s tokens"):format(formatValue(totalValue(State.otherItems)))
    addBtn.Visible = lc < MAX_ITEMS
end

local function resetAccepted()
    State.localAccepted = false
    State.otherAccepted = false
    State.execAt = nil
    if State.execCountdown then task.cancel(State.execCountdown) State.execCountdown = nil end
    countdownOverlay.Visible = false
end

local function stepUI()
    localUI.acceptedLbl.Visible = State.localAccepted
    otherUI.acceptedLbl.Visible = State.otherAccepted
    acceptBtn.BackgroundColor3 = State.localAccepted
        and Color3.fromRGB(40,100,60) or Color3.fromRGB(40,160,80)
    simAcceptBtn.BackgroundColor3 = State.otherAccepted
        and Color3.fromRGB(80,30,30) or Color3.fromRGB(30,100,55)
    simAcceptBtn.Text = State.otherAccepted and "↩ Unaccept" or "✓ Accept"
end

