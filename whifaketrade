-- helpers
local function newInst(class, props, parent)
    local o = Instance.new(class)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end

local function label(text, size, weight, color, parent, props)
    local p = props or {}
    p.Text              = text
    p.Font              = weight == "bold" and Enum.Font.GothamBold or Enum.Font.Gotham
    p.TextSize          = size
    p.TextColor3        = color or Color3.fromRGB(240,240,240)
    p.BackgroundTransparency = 1
    p.Size              = p.Size or UDim2.new(1, 0, 0, size + 6)
    p.TextXAlignment    = p.TextXAlignment or Enum.TextXAlignment.Left
    local lbl = newInst("TextLabel", p, parent)
    return lbl
end

local function btn(text, size, bg, tc, parent, props)
    local p = props or {}
    p.Text              = text
    p.Font              = Enum.Font.GothamBold
    p.TextSize          = size or 13
    p.TextColor3        = tc or Color3.fromRGB(255,255,255)
    p.BackgroundColor3  = bg or Color3.fromRGB(60,120,220)
    p.AutoButtonColor   = true
    p.Size              = p.Size or UDim2.new(1, 0, 0, 32)
    local b = newInst("TextButton", p, parent)
    newInst("UICorner", { CornerRadius = UDim.new(0, 6) }, b)
    return b
end

local function frame(bg, parent, props)
    local p = props or {}
    p.BackgroundColor3  = bg
    p.BorderSizePixel   = 0
    local f = newInst("Frame", p, parent)
    return f
end

local function scrollFrame(parent, props)
    local p = props or {}
    p.BackgroundTransparency = 1
    p.CanvasSize         = UDim2.new(0,0,0,0)
    p.AutomaticCanvasSize = Enum.AutomaticSize.Y
    p.ScrollBarThickness = 4
    p.ScrollBarImageColor3 = Color3.fromRGB(100,100,120)
    local sf = newInst("ScrollingFrame", p, parent)
    return sf
end

local function corner(r, parent)
    newInst("UICorner", { CornerRadius = UDim.new(0, r) }, parent)
end

local function pad(t, r, b, l, parent)
    newInst("UIPadding", {
        PaddingTop    = UDim.new(0, t),
        PaddingRight  = UDim.new(0, r),
        PaddingBottom = UDim.new(0, b),
        PaddingLeft   = UDim.new(0, l),
    }, parent)
end

local function listLayout(dir, align, gap, parent)
    return newInst("UIListLayout", {
        FillDirection   = dir or Enum.FillDirection.Vertical,
        HorizontalAlignment = align or Enum.HorizontalAlignment.Left,
        SortOrder       = Enum.SortOrder.LayoutOrder,
        Padding         = UDim.new(0, gap or 6),
    }, parent)
end

local function gridLayout(cellSize, cellPad, parent)
    return newInst("UIGridLayout", {
        CellSize        = cellSize or UDim2.new(0, 72, 0, 80),
        CellPaddingSize = cellPad or UDim2.new(0, 6, 0, 6),
        SortOrder       = Enum.SortOrder.LayoutOrder,
    }, parent)
end

