        Color = (itemData.value or 0) >= 500000 and Color3.fromRGB(255,200,80) or Color3.fromRGB(70,70,90),
        Thickness = (itemData.value or 0) >= 500000 and 1 or 0.5,
        Transparency = 0.3,
    }, slot)

    local emojiLbl = label(itemData.emoji or "?", 26, nil, Color3.fromRGB(255,255,255), slot, {
        Size=UDim2.new(1,0,0,36), Position=UDim2.new(0,0,0,6),
        TextXAlignment=Enum.TextXAlignment.Center,
    })
    local nameLbl = label(itemData.name, 9, nil, Color3.fromRGB(200,200,220), slot, {
        Size=UDim2.new(1,-4,0,22), Position=UDim2.new(0,2,0,38),
        TextXAlignment=Enum.TextXAlignment.Center,
        TextWrapped=true,
    })
    if itemData.amt and itemData.amt > 1 then
        label("x"..itemData.amt, 9, nil, Color3.fromRGB(255,200,80), slot, {
            Size=UDim2.new(1,0,0,12), Position=UDim2.new(0,0,0,62),
            TextXAlignment=Enum.TextXAlignment.Center,
        })
    end

    if isLocal then
        local rb = newInst("TextButton", {
            Text="✕", Font=Enum.Font.GothamBold, TextSize=9,
            TextColor3=Color3.fromRGB(255,100,100),
            BackgroundColor3=Color3.fromRGB(60,20,20),
            BorderSizePixel=0,
            Size=UDim2.new(0,14,0,14), Position=UDim2.new(1,-16,0,2),
            ZIndex=slot.ZIndex+1,
        }, slot)
        corner(4, rb)
        rb.MouseButton1Click:Connect(function()
            -- remove item
            State.localItems[slotId] = nil
            State.localSlotUsed[slotId] = nil
            slot:Destroy()
            resetAccepted()
            State.canProceedAt = os.clock() + ACCEPT_DELAY
            updateLabels()
            stepUI()
        end)
    end

    return slot
end

-- ─── INVENTORY PICKER ────────────────────────────────────────────────────────

local pendingQtyResolve = nil

local function openQtyPicker(itemData, maxAmt)
    qtyTitle.Text = "How many to add?"
    qtyInfo.Text  = itemData.name .. " (max " .. maxAmt .. ")"
    qtyBox.Text   = "1"
    qtyOverlay.Visible = true

    local conn1, conn2
    local function finish(confirmed)
        qtyOverlay.Visible = false
        if conn1 then conn1:Disconnect() end
        if conn2 then conn2:Disconnect() end
        local amt = tonumber(qtyBox.Text)
        if not confirmed or not amt then
            if pendingQtyResolve then pendingQtyResolve(false, nil) pendingQtyResolve=nil end
            return
        end
        amt = math.clamp(math.floor(amt), 1, maxAmt)
        if pendingQtyResolve then pendingQtyResolve(true, amt) pendingQtyResolve=nil end
    end

    conn1 = qtyConfirm.MouseButton1Click:Connect(function() finish(true) end)
    conn2 = qtyCancel.MouseButton1Click:Connect(function() finish(false) end)
end

local function openInventoryPicker()
    -- clear previous list
    for _, c in ipairs(invList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end

    for idx, item in ipairs(FAKE_INVENTORY) do
        local alreadyAdded = State.localSlotUsed[idx] == true
        local rowBg = alreadyAdded and Color3.fromRGB(28,28,38) or ITEM_BG
        local row = newInst("TextButton", {
            Text="", BackgroundColor3=rowBg, BorderSizePixel=0,
            Size=UDim2.new(1,0,0,44), LayoutOrder=idx, AutoButtonColor=not alreadyAdded,
            Active=not alreadyAdded,
        }, invList)
        corner(6, row)
        newInst("UIStroke", { Color=Color3.fromRGB(60,60,80), Thickness=0.5 }, row)

        label(item.emoji, 20, nil, Color3.fromRGB(255,255,255), row, {
            Size=UDim2.new(0,36,1,0), Position=UDim2.new(0,6,0,0),
            TextXAlignment=Enum.TextXAlignment.Center,
        })
        label(item.name, 12, "bold", alreadyAdded and MUTED or Color3.fromRGB(220,220,240), row, {
            Size=UDim2.new(1,-110,0,18), Position=UDim2.new(0,44,0,6),
        })
        local valStr = formatValue(item.value) .. " tokens"
        if item.stackable and item.amt then valStr = valStr .. "  ·  x"..item.amt end
        label(valStr, 10, nil, alreadyAdded and Color3.fromRGB(60,60,80) or MUTED, row, {
            Size=UDim2.new(1,-110,0,14), Position=UDim2.new(0,44,0,24),
        })

        if alreadyAdded then
            label("already added", 10, nil, Color3.fromRGB(80,80,100), row, {
                Size=UDim2.new(0,80,1,0), Position=UDim2.new(1,-84,0,0),
                TextXAlignment=Enum.TextXAlignment.Right,
            })
        else
            local lc = 0 for _ in pairs(State.localItems) do lc+=1 end
            if lc < MAX_ITEMS then
                row.MouseButton1Click:Connect(function()
                    invOverlay.Visible = false
                    local chosenItem = FAKE_INVENTORY[idx]
                    local function doAdd(amt)
                        State.localItems[idx] = { name=chosenItem.name, emoji=chosenItem.emoji, value=chosenItem.value, amt=amt }
                        State.localSlotUsed[idx] = true
                        makeItemSlot(localUI.offerGrid, State.localItems[idx], idx, true)
                        resetAccepted()
                        State.canProceedAt = os.clock() + ACCEPT_DELAY
                        updateLabels()
                        stepUI()
                    end
                    if chosenItem.stackable and (chosenItem.amt or 1) > 1 then
                        pendingQtyResolve = function(ok, amt)
                            if ok then doAdd(amt) end
                        end
                        openQtyPicker(chosenItem, chosenItem.amt)
                    else
                        doAdd(1)
                    end
                end)
            end
        end
    end

    invOverlay.Visible = true
end

-- ─── TRADE LOGIC ─────────────────────────────────────────────────────────────

local function executeTrade()
    -- Summarise what was traded
    local lNames, oNames = {}, {}
    for _, it in pairs(State.localItems) do table.insert(lNames, it.emoji.." "..it.name) end
    for _, it in pairs(State.otherItems) do table.insert(oNames, it.emoji.." "..it.name) end
    local summary = ""
    if #lNames > 0 then summary = summary .. "You gave: "..table.concat(lNames,", ")..".\n" end
    if #oNames > 0 then summary = summary .. "You received: "..table.concat(oNames,", ").."." end
    if summary == "" then summary = "Both sides offered nothing." end

    resultSub.Text = summary
    resultOverlay.Visible = true
    resultIcon.TextColor3 = SUCCESS
    resultTitle.Text = "Trade Executed!"
    newInst("UIStroke", { Color=SUCCESS, Thickness=1, Transparency=0.3 }, resultOverlay):Destroy()
    newInst("UIStroke", { Color=SUCCESS, Thickness=1, Transparency=0.3 }, resultOverlay)

    -- close trade window (keep result open)
    tradeWin.Visible = false
    simPanel.Visible = false
    State.active = false
end

local function startExecCountdown()
    State.execAt = os.clock() + FINAL_EXEC_DELAY
    countdownOverlay.Visible = true

    if State.execCountdown then task.cancel(State.execCountdown) end
    State.execCountdown = task.spawn(function()
        while State.execAt and os.clock() < State.execAt do
            local remaining = math.ceil(State.execAt - os.clock())
            cdLabel.Text = ("Trade executes in %d..."):format(remaining)
            task.wait(0.1)
        end
        if State.execAt then
            countdownOverlay.Visible = false
            executeTrade()
        end
    end)
end

local function tryBothAccepted()
    if State.localAccepted and State.otherAccepted then
        startExecCountdown()
    end
end

local function processLocalAccept()
    if State.localAccepted then
        -- unaccept
        State.localAccepted = false
        if State.execCountdown then task.cancel(State.execCountdown) State.execCountdown=nil end
        State.execAt = nil
        countdownOverlay.Visible = false
        stepUI()
        return
    end

    local delay = State.canProceedAt - os.clock()
    if delay > 0 then
        showAlert(("Wait %.1f more seconds before accepting."):format(delay), Color3.fromRGB(255,180,80))
        return
    end

    local lc = 0 for _ in pairs(State.localItems) do lc+=1 end
    local oc = 0 for _ in pairs(State.otherItems) do oc+=1 end
    if lc == 0 and oc == 0 then
        showAlert("Add at least one item before accepting.")
        return
    end

    State.localAccepted = true
    stepUI()
    tryBothAccepted()
end

local function cancelTrade(reason)
    State.active = false
    if State.execCountdown then task.cancel(State.execCountdown) State.execCountdown=nil end
    tradeWin.Visible = false
    simPanel.Visible = false
    State.localItems = {}
    State.otherItems = {}
    State.localSlotUsed = {}
    State.otherSlotUsed = {}
    resetAccepted()
    if reason then
        showAlert(reason, DANGER)
    end
end

-- ─── SIM OTHER ───────────────────────────────────────────────────────────────

local function simAddOtherItem()
    local oc = 0 for _ in pairs(State.otherItems) do oc+=1 end
    if oc >= MAX_ITEMS then
        showAlert("Other player is at item cap.", Color3.fromRGB(255,180,80))
        return
    end

    -- find next unused
    local picked = nil
    for idx, item in ipairs(OTHER_INVENTORY) do
        if not State.otherSlotUsed[idx] then
            picked = { idx=idx, item=item }
            break
        end
    end
    if not picked then
        showAlert("No more fake items for other player.", MUTED)
        return
    end

    State.otherItems[picked.idx]    = { name=picked.item.name, emoji=picked.item.emoji, value=picked.item.value, amt=picked.item.amt or 1 }
    State.otherSlotUsed[picked.idx] = true
    makeItemSlot(otherUI.offerGrid, State.otherItems[picked.idx], picked.idx, false)
    resetAccepted()
    State.canProceedAt = os.clock() + ACCEPT_DELAY
    updateLabels()
    stepUI()
end

local function simRemoveOtherItem()
    local lastKey = nil
    for k in pairs(State.otherItems) do lastKey = k end
    if not lastKey then
        showAlert("Other side has no items to remove.", MUTED)
        return
    end
    State.otherItems[lastKey] = nil
    State.otherSlotUsed[lastKey] = nil
    local slot = otherUI.offerGrid:FindFirstChild("Slot_"..tostring(lastKey))
    if slot then slot:Destroy() end
    resetAccepted()
    State.canProceedAt = os.clock() + ACCEPT_DELAY
    updateLabels()
    stepUI()
end

local function simOtherAccept()
    if State.otherAccepted then
        State.otherAccepted = false
        if State.execCountdown then task.cancel(State.execCountdown) State.execCountdown=nil end
        State.execAt = nil
        countdownOverlay.Visible = false
        stepUI()
        return
    end
    State.otherAccepted = true
    stepUI()
    tryBothAccepted()
end

-- ─── TRADE START ─────────────────────────────────────────────────────────────

local function startTrade()
    if State.active then return end

    local name = nameBox.Text ~= "" and nameBox.Text or "TestPlayer"
    State.otherName   = name
    State.active      = true
    State.localItems  = {}
    State.otherItems  = {}
    State.localSlotUsed = {}
    State.otherSlotUsed = {}
    resetAccepted()
    State.canProceedAt = 0

    -- clear item grids
    for _, c in ipairs(localUI.offerGrid:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    for _, c in ipairs(otherUI.offerGrid:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    headerTitle.Text = ("Trading with %s"):format(name)
    otherUI.playerLbl.Text = name

    -- Level check
    if FAKE_PLAYER_LEVEL < LEVEL_REQUIRED then
        showAlert(("Need level %d to trade (simulated level: %d)"):format(LEVEL_REQUIRED, FAKE_PLAYER_LEVEL), DANGER)
        State.active = false
        return
    end

    statusLabel.Text = "● LIVE"
    statusLabel.TextColor3 = SUCCESS
    alertBanner.Visible = false

    updateLabels()
    stepUI()
    tradeWin.Visible = true
    simPanel.Visible = true
    addBtn.Visible   = true

    -- scam warning for low-level simulation
    if FAKE_PLAYER_LEVEL <= 50 then
        showAlert("Simulating scam warning for low-level player.", Color3.fromRGB(255,180,80), 4)
    end
end

