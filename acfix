-- Virtual Input Manager Functions
local function getScreenSize()
    return Camera.ViewportSize
end

local function getClickPosition()
    local screenSize = getScreenSize()
    local x = screenSize.X - 300
    local y = 30
    return x, y
end

local function clickAt(x, y)
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

local function startAutoClicker()
    if clickLoop then
        task.cancel(clickLoop)
    end
    clickLoop = task.spawn(function()
        while true do
            if not isPaused then
                local x, y = getClickPosition()
                clickAt(x, y)
            end
            task.wait(1) -- Once per second
        end
    end)
end

-- Tween movement function
local function tweenToPosition(model, targetPos, speed)
    speed = speed or 50
    local primaryPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if not primaryPart then return end

    local distance = (targetPos - primaryPart.Position).Magnitude
    local duration = distance / speed

    local targetCFrame = CFrame.new(targetPos)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(primaryPart, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
end

