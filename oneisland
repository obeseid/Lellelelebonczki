-- Virtual Input Manager Functions
local function getClickPosition()
    local screenSize = Camera.ViewportSize
    local x = screenSize.X - 300
    local y = 30
    return x, y
end

local function clickAt(x, y)
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

local function startAutoClicker()
    if clickLoop then
        task.cancel(clickLoop)
    end
    clickLoop = task.spawn(function()
        while true do
            if not isPaused then
                local x, y = getClickPosition()
                clickAt(x, y)
            end
            task.wait(1)
        end
    end)
end

-- Tween player to position
local function tweenToPosition(targetPos, speed)
    speed = speed or 50
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local distance = (targetPos - hrp.Position).Magnitude
    if distance < 0.5 then return end
    local duration = distance / speed

    local targetCFrame = CFrame.new(targetPos, targetPos + hrp.CFrame.LookVector)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
end

