		:WaitForChild("List")

	for _, category in ipairs(inventoryList:GetChildren()) do
		if category.Name == "CategoryContainer" then
			monitorCategory(category)
		end
	end

	inventoryList.ChildAdded:Connect(function(child)
		if child.Name == "CategoryContainer" then
			task.wait(0.5)
			monitorCategory(child)
		end
	end)
