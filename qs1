local latestItemID = nil

local function monitorCategory(categoryContainer)
	local list = categoryContainer:FindFirstChild("List")
	if not list then return end

	local hasTextButton = false
	for _, child in ipairs(list:GetChildren()) do
		if child:IsA("TextButton") then
			hasTextButton = true
			break
		end
	end

	if not hasTextButton then return end

	print("Monitoring list in: " .. categoryContainer.Name)

	list.ChildAdded:Connect(function(child)
		if child:IsA("TextButton") then
			latestItemID = child.Name
			print("New item detected, ItemID: " .. latestItemID)
		end
	end)
end

local function monitorBackpack()
	local inventoryList = playerGui:WaitForChild("Menus")
